import pandas as pd
import numpy as np
import joblib

from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import OneHotEncoder

from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier

from sklearn.metrics import (
    accuracy_score,
    f1_score,
    roc_auc_score,
    classification_report,
    confusion_matrix
)


df = pd.read_parquet("../data/ml_ready.parquet")

print(df.shape)
df.head()


train_df = df[df["split"] == "train"].copy()
test_df = df[df["split"] == "test"].copy()

print("Train:", train_df.shape)
print("Test :", test_df.shape)


features = [
    "event_type",
    "event_cause",
    "corridor",
    "veh_type",
    "geo_cluster",
    "hour",
    "day_of_week",
    "is_weekend",
    "latitude",
    "longitude"
]

categorical_features = [
    "event_type",
    "event_cause",
    "corridor",
    "veh_type",
    "geo_cluster"
]

numerical_features = [
    "hour",
    "day_of_week",
    "is_weekend",
    "latitude",
    "longitude"
]


preprocessor = ColumnTransformer(
    transformers=[
        (
            "cat",
            OneHotEncoder(handle_unknown="ignore"),
            categorical_features
        ),
        (
            "num",
            "passthrough",
            numerical_features
        )
    ]
)


X_train = train_df[features]
X_test = test_df[features]

y_train_priority = train_df["y_priority"]
y_test_priority = test_df["y_priority"]

print(y_train_priority.value_counts())


lr_pipeline = Pipeline([
    ("preprocessor", preprocessor),
    ("model", LogisticRegression(max_iter=1000))
])

lr_pipeline.fit(X_train, y_train_priority)

lr_preds = lr_pipeline.predict(X_test)
lr_probs = lr_pipeline.predict_proba(X_test)[:, 1]


print("=== LOGISTIC REGRESSION ===")

print("Accuracy:",
      accuracy_score(y_test_priority, lr_preds))

print("F1:",
      f1_score(y_test_priority, lr_preds))

print("ROC AUC:",
      roc_auc_score(y_test_priority, lr_probs))

print("\nClassification Report")
print(classification_report(y_test_priority, lr_preds))

print("\nConfusion Matrix")
print(confusion_matrix(y_test_priority, lr_preds))


rf_priority = Pipeline([
    ("preprocessor", preprocessor),
    (
        "model",
        RandomForestClassifier(
            n_estimators=300,
            max_depth=15,
            random_state=42
        )
    )
])

rf_priority.fit(X_train, y_train_priority)

rf_preds = rf_priority.predict(X_test)
rf_probs = rf_priority.predict_proba(X_test)[:, 1]


print("=== RANDOM FOREST ===")

print("Accuracy:",
      accuracy_score(y_test_priority, rf_preds))

print("F1:",
      f1_score(y_test_priority, rf_preds))

print("ROC AUC:",
      roc_auc_score(y_test_priority, rf_probs))

print("\nClassification Report")
print(classification_report(y_test_priority, rf_preds))

print("\nConfusion Matrix")
print(confusion_matrix(y_test_priority, rf_preds))


y_train_closure = train_df["y_closure"]
y_test_closure = test_df["y_closure"]

print(y_train_closure.value_counts())


rf_closure = Pipeline([
    ("preprocessor", preprocessor),
    (
        "model",
        RandomForestClassifier(
            n_estimators=400,
            max_depth=15,
            class_weight="balanced",
            random_state=42
        )
    )
])

rf_closure.fit(X_train, y_train_closure)

closure_preds = rf_closure.predict(X_test)
closure_probs = rf_closure.predict_proba(X_test)[:, 1]


print("=== ROAD CLOSURE MODEL ===")

print("Accuracy:",
      accuracy_score(y_test_closure, closure_preds))

print("F1:",
      f1_score(y_test_closure, closure_preds))

print("ROC AUC:",
      roc_auc_score(y_test_closure, closure_probs))

print("\nClassification Report")
print(classification_report(y_test_closure, closure_preds))

print("\nConfusion Matrix")
print(confusion_matrix(y_test_closure, closure_preds))


rf_model = rf_priority.named_steps["model"]

feature_names = (
    rf_priority.named_steps["preprocessor"]
    .get_feature_names_out()
)

importance_df = pd.DataFrame({
    "feature": feature_names,
    "importance": rf_model.feature_importances_
})

importance_df = importance_df.sort_values(
    "importance",
    ascending=False
)

importance_df.head(10)


import os

os.makedirs("../backend/saved_models", exist_ok=True)

print("Folder created")


joblib.dump(
    rf_priority,
    "../backend/saved_models/priority_model.pkl"
)

joblib.dump(
    rf_closure,
    "../backend/saved_models/closure_model.pkl"
)

joblib.dump(
    preprocessor,
    "../backend/saved_models/preprocessor.pkl"
)

print("Models saved successfully")


importance_df.head(20)


pd.crosstab(
    df["corridor"],
    df["priority"],
    normalize="index"
).round(3)



